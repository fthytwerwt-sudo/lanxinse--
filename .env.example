# 阿里云百炼 / DashScope API Key（接口密钥）
# 使用方法：复制本文件为 .env，然后只在 .env 里填写真实 key
# 注意：不要把真实 key 写进 .env.example，也不要提交 .env
ALI_API_KEY=

# 阿里 API Base URL（接口基础地址）
# 如果你的阿里控制台文档给了不同地址，以控制台为准
ALI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认文本分析模型（用于结构总结、规则归纳、候选解释）
# 状态：待验证
ALI_MODEL_TEXT_ANALYSIS=qwen-plus-latest

# 默认视觉理解模型（用于图片 / 关键帧理解）
# 状态：待验证
ALI_MODEL_VISION_ANALYSIS=qwen-vl-plus-latest

# 默认高质量视觉理解模型（用于复杂画面、关键样本复核）
# 状态：待验证
ALI_MODEL_VISION_HIGH=qwen-vl-max-latest

# 默认音视频理解模型（用于音频 + 视频综合理解）
# 状态：待验证
ALI_MODEL_OMNI_ANALYSIS=qwen-omni-turbo-latest

# 默认结构化输出模型（用于 JSON 输出修正、字段归一）
# 状态：待验证
ALI_MODEL_STRUCTURED_OUTPUT=qwen-plus-latest

# 是否真实调用 API
# false = 只检查配置，不真实调用
# true = 允许连接测试
ALI_API_ENABLE_LIVE_TEST=false

# API 请求超时时间，单位秒
ALI_API_TIMEOUT_SECONDS=60

# 单次最多处理视频数量，用于防止误跑全量
ALI_MAX_VIDEOS_PER_RUN=3

# 单次最多抽帧数量，用于控制成本
ALI_MAX_FRAMES_PER_VIDEO=12

# 是否允许上传或传入视频 URL 给阿里 API
# 本轮默认 false，后续全量解析前再确认
ALI_ALLOW_VIDEO_UPLOAD=false
